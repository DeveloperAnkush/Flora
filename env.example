# MongoDB Atlas connection string
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# Network Access: allow your IP (or 0.0.0.0/0 for development)
# Database Access: create a user with read/write permissions
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/flora-billing?retryWrites=true&w=majority

# Secret key for JWT session tokens (use a long random string)
AUTH_SECRET=your-super-secret-random-string-at-least-32-chars
